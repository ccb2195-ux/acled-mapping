df <- df |>
mutate(WEEK = as.Date(WEEK))
glimpse(df)
df |>
count(WEEK, SUB_EVENT_TYPE) |>
ggplot(aes(x = WEEK, y = n, color = SUB_EVENT_TYPE)) +
geom_line() +
theme_minimal()
df |>
count(WEEK, SUB_EVENT_TYPE) |>
ggplot(aes(x = WEEK, y = n)) +
geom_line() +
facet_wrap(~ SUB_EVENT_TYPE) +
theme_minimal()
df |>
filter(SUB_EVENT_TYPE != "Peaceful protest") |>
